# ============================================================
# LegacyBridge - Variables de Entorno (TEMPLATE)
# ============================================================
# Copia este archivo como .env y completa los valores:
#   cp .env.example .env
# ============================================================

# --- NVIDIA NIM API ---
NVIDIA_API_KEY=tu-api-key-aqui
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=meta/llama-4-maverick-17b-128e-instruct

# --- Podman / Contenedores ---
PODMAN_RUST_IMAGE=docker.io/library/rust:1-alpine
PODMAN_JAVA_IMAGE=docker.io/library/eclipse-temurin:17-jdk-alpine

# --- Pipeline ---
MIGRATION_MAX_RETRIES=2
MIGRATION_TIMEOUT=300
